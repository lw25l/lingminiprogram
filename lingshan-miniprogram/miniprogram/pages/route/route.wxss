/* pages/route/route.wxss */

.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg-primary);
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  background: white;
  border-bottom: 1rpx solid var(--border-color);
}

.filter-item {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
}

.filter-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.filter-options {
  display: flex;
  gap: 12rpx;
}

.filter-opt {
  padding: 8rpx 20rpx;
  background: var(--bg-primary);
  color: var(--text-secondary);
  font-size: 24rpx;
  border-radius: 20rpx;
}

.filter-opt.active {
  background: var(--primary-color);
  color: white;
}

.filter-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.filter-tag {
  padding: 6rpx 16rpx;
  background: rgba(74, 144, 217, 0.1);
  color: var(--primary-color);
  font-size: 22rpx;
  border-radius: 8rpx;
}

/* 路线列表 */
.route-list {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx;
}

.route-card {
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.route-header {
  display: flex;
}

.route-cover {
  width: 320rpx;
  height: 240rpx;
}

.route-info {
  flex: 1;
  padding: 24rpx;
}

.route-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}

.route-meta {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
}

.meta-item {
  font-size: 24rpx;
  color: var(--text-light);
}

.highlight-section {
  padding: 24rpx;
  border-top: 1rpx solid var(--border-color);
}

.highlight-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.highlight-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.highlight-tag {
  padding: 8rpx 16rpx;
  background: rgba(74, 144, 217, 0.1);
  color: var(--primary-color);
  font-size: 24rpx;
  border-radius: 8rpx;
}

.stops-section {
  padding: 24rpx;
  border-top: 1rpx solid var(--border-color);
}

.stops-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.stop-list {
  margin-top: 16rpx;
}

.stop-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: var(--bg-primary);
  border-radius: 12rpx;
  margin-bottom: 10rpx;
}

.stop-order {
  width: 36rpx;
  height: 36rpx;
  background: var(--primary-color);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 600;
}

.stop-content {
  flex: 1;
  margin-left: 16rpx;
}

.stop-name {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
}

.stop-time {
  font-size: 24rpx;
  color: var(--text-light);
}

.actions-section {
  padding: 24rpx;
  border-top: 1rpx solid var(--border-color);
}

.btn-primary, .btn-secondary {
  width: 100%;
}

.btn-secondary {
  margin-top: 12rpx;
}

/* 底部导航 */
.bottom-nav {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 16rpx 0;
  background: white;
  border-top: 1rpx solid var(--border-color);
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.nav-icon {
  width: 44rpx;
  height: 44rpx;
}

.nav-label {
  font-size: 22rpx;
  color: var(--text-light);
}

.nav-item.active .nav-label {
  color: var(--primary-color);
}
