/* pages/index/index.wxss */

.page-container {
  min-height: 100vh;
  background: var(--bg-primary);
  padding-bottom: 30rpx;
}

/* Banner */
.banner-section {
  position: relative;
  height: 420rpx;
}

.banner-swiper {
  width: 100%;
  height: 100%;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx 30rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.6));
  color: white;
}

.banner-title {
  font-size: 48rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 10rpx;
}

.banner-subtitle {
  font-size: 28rpx;
  opacity: 0.9;
}

/* 快捷入口 */
.quick-actions {
  display: flex;
  justify-content: space-around;
  padding: 30rpx 20rpx;
  background: white;
  margin: -30rpx 30rpx 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
  position: relative;
  z-index: 10;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.action-icon image {
  width: 60rpx;
  height: 60rpx;
}

.chat-icon { background: linear-gradient(135deg, #4A90D9, #6BA8E5); }
.map-icon { background: linear-gradient(135deg, #52C41A, #73D13D); }
.route-icon { background: linear-gradient(135deg, #FFB347, #FFCC66); }
.ticket-icon { background: linear-gradient(135deg, #9254DE, #B37FEB); }

.action-text {
  font-size: 26rpx;
  color: var(--text-primary);
}

/* Section通用样式 */
.section {
  padding: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.section-more {
  font-size: 26rpx;
  color: var(--primary-color);
}

/* 兴趣标签 */
.interest-tags {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.interest-tip {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 20rpx;
}

.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.confirm-btn {
  width: 100%;
  margin-top: 20rpx;
}

/* 推荐景点列表 */
.recommend-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.attraction-card {
  display: flex;
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.attraction-card .attraction-image {
  width: 240rpx;
  height: 180rpx;
  flex-shrink: 0;
}

.attraction-card .attraction-info {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.attraction-card .attraction-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.attraction-card .attraction-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.attraction-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.mini-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  background: rgba(74, 144, 217, 0.1);
  color: var(--primary-color);
  border-radius: 4rpx;
}

/* 热门景点横向滚动 */
.hot-attractions {
  white-space: nowrap;
  margin: 0 -10rpx;
}

.attraction-item {
  display: inline-block;
  width: 280rpx;
  margin: 0 10rpx;
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.attraction-cover {
  width: 100%;
  height: 200rpx;
}

.attraction-content {
  padding: 20rpx;
  white-space: normal;
}

.attraction-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.attraction-meta {
  display: flex;
  align-items: center;
}

.meta-item {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 今日活动 */
.activity-list {
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
}

.activity-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.activity-card:last-child {
  border-bottom: none;
}

.activity-time {
  width: 120rpx;
  flex-shrink: 0;
}

.time-value {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary-color);
}

.activity-info {
  flex: 1;
  padding: 0 20rpx;
}

.activity-name {
  font-size: 28rpx;
  color: var(--text-primary);
  display: block;
  margin-bottom: 6rpx;
}

.activity-location {
  font-size: 24rpx;
  color: var(--text-light);
}

.activity-action {
  flex-shrink: 0;
}

.action-btn {
  font-size: 26rpx;
  color: var(--primary-color);
  padding: 10rpx 20rpx;
  background: rgba(74, 144, 217, 0.1);
  border-radius: 30rpx;
}

/* 实用信息 */
.info-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.info-item {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.info-icon {
  width: 60rpx;
  height: 60rpx;
  margin-bottom: 12rpx;
}

.info-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 6rpx;
}

.info-value {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}
