<!--pages/profile/profile.wxml-->
<view class="page-container">
  <!-- 个人信息卡片 -->
  <view class="user-card" wx:if="{{!loggedIn}}">
    <image class="avatar" src="/assets/images/default-avatar.png" mode="aspectFill"></image>
    <text class="welcome-text">欢迎来到灵山胜境</text>
    <text class="hint-text">登录后享受更多功能</text>
    <button class="btn-login" bindtap="goToLogin">立即登录</button>
  </view>

  <view class="user-card" wx:else>
    <view class="user-header">
      <image class="avatar" src="{{userInfo.avatarUrl || '/assets/images/default-avatar.png'}}" mode="aspectFill"></image>
      <view class="user-info">
        <text class="username">{{userInfo.nickname || userInfo.openid}}</text>
        <text class="user-desc">游客/会员</text>
      </view>
      <image class="edit-btn" src="/assets/icons/edit.png" mode="aspectFit" bindtap="editProfile"></image>
    </view>

    <!-- 数据统计 -->
    <view class="stats-section">
      <view class="stat-item" bindtap="showVisitCount">
        <text class="stat-num">{{visitCount}}</text>
        <text class="stat-label">已游览景点</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item" bindtap="showChatHistory">
        <text class="stat-num">{{chatCount}}</text>
        <text class="stat-label">对话次数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item" bindtap="showSatisfaction">
        <text class="stat-num">{{satisfactionScore}}</text>
        <text class="stat-label">满意度</text>
      </view>
    </view>

    <!-- 功能菜单 -->
    <view class="menu-section">
      <view class="menu-item" bindtap="goToRoute">
        <image class="menu-icon" src="/assets/icons/route.png" mode="aspectFit"></image>
        <text class="menu-title">我的路线</text>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="goToVisited">
        <image class="menu-icon" src="/assets/icons/history.png" mode="aspectFit"></image>
        <text class="menu-title">游览记录</text>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="goToFeedback">
        <image class="menu-icon" src="/assets/icons/feedback.png" mode="aspectFit"></image>
        <text class="menu-title">意见反馈</text>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="goToSettings">
        <image class="menu-icon" src="/assets/icons/settings.png" mode="aspectFit"></image>
        <text class="menu-title">设置</text>
        <text class="menu-arrow">></text>
      </view>
    </view>

    <!-- 关于我们 -->
    <view class="about-section">
      <view class="section-title">关于我们</view>
      <view class="about-text">
        <text>灵山胜境AI智能导览系统</text>
        <text>为您提供7x24小时智能导游服务</text>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-modal" wx:if="{{showLogoutModal}}" bindtap="hideLogoutModal">
    <view class="modal-content" catchtap="stopPropagation">
      <text class="modal-title">确认退出？</text>
      <text class="modal-desc">退出后需要重新登录</text>
      <view class="modal-actions">
        <view class="modal-btn cancel" bindtap="hideLogoutModal">取消</view>
        <view class="modal-btn confirm" bindtap="doLogout">退出</view>
      </view>
    </view>
  </view>
</view>
