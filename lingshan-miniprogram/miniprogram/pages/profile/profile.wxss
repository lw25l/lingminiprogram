/* pages/profile/profile.wxss */

.page-container {
  min-height: 100vh;
  background: var(--bg-primary);
  padding-bottom: 30rpx;
}

/* 用户卡片 */
.user-card {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  margin: 30rpx;
  border-radius: 20rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 30rpx rgba(74, 144, 217, 0.3);
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.8);
  margin-bottom: 20rpx;
}

.welcome-text {
  font-size: 34rpx;
  font-weight: 600;
  color: white;
  margin-bottom: 10rpx;
}

.hint-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 30rpx;
}

.btn-login {
  background: white;
  color: var(--primary-color);
  border: none;
  padding: 20rpx 60rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 500;
}

/* 用户头部 */
.user-header {
  width: 100%;
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.user-info {
  flex: 1;
  margin-left: 20rpx;
}

.username {
  font-size: 34rpx;
  font-weight: 600;
  color: white;
  display: block;
  margin-bottom: 6rpx;
}

.user-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.edit-btn {
  width: 50rpx;
  height: 50rpx;
  opacity: 0.8;
}

/* 数据统计 */
.stats-section {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 24rpx 0;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 600;
  color: white;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
}

/* 功能菜单 */
.menu-section {
  background: white;
  margin: 30rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 50rpx;
  height: 50rpx;
  margin-right: 20rpx;
}

.menu-title {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-primary);
}

.menu-arrow {
  font-size: 28rpx;
  color: var(--text-light);
}

/* 关于我们 */
.about-section {
  background: white;
  margin: 30rpx;
  border-radius: 20rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.about-text {
  display: flex;
  flex-direction: column;
}

.about-text text {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* 退出登录弹窗 */
.logout-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 560rpx;
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
  text-align: center;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 20rpx;
}

.modal-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 40rpx;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.modal-btn.cancel {
  background: var(--bg-primary);
  color: var(--text-secondary);
}

.modal-btn.confirm {
  background: var(--error-color);
  color: white;
}
