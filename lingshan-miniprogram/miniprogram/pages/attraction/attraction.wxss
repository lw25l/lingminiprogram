/* pages/attraction/attraction.wxss */

.page-container {
  min-height: 100vh;
  background: var(--bg-primary);
}

/* 顶部信息栏 */
.header-bar {
  display: flex;
  align-items: center;
  position: relative;
  height: 88rpx;
  background: white;
  border-bottom: 1rpx solid var(--border-color);
}

.back-btn {
  width: 44rpx;
  height: 44rpx;
  margin-left: 20rpx;
}

.attraction-name {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.attraction-id {
  position: absolute;
  right: 20rpx;
  font-size: 24rpx;
  color: var(--text-light);
}

/* 轮播图 */
.banner-carousel {
  height: 400rpx;
}

.banner-slide {
  width: 100%;
  height: 100%;
}

/* 信息区块 */
.info-section {
  background: white;
  padding: 30rpx;
  margin-top: -20rpx;
}

.info-card {
  background: var(--bg-primary);
  border-radius: 16rpx;
  padding: 30rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.info-value {
  font-size: 28rpx;
  color: var(--text-primary);
}

.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.mini-tag {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  background: rgba(74, 144, 217, 0.1);
  color: var(--primary-color);
  border-radius: 8rpx;
}

/* 详细内容 */
.detail-section {
  background: white;
  padding: 30rpx;
  margin-top: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.detail-content {
  font-size: 28rpx;
  line-height: 1.8;
  color: var(--text-secondary);
}

/* 提示列表 */
.tips-section {
  background: white;
  padding: 30rpx;
  margin-top: 20rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx;
  background: var(--bg-primary);
  border-radius: 12rpx;
}

.tip-icon {
  width: 40rpx;
  height: 40rpx;
}

.tip-item text {
  font-size: 28rpx;
  color: var(--text-primary);
}

/* 相关景点 */
.related-section {
  background: white;
  padding: 30rpx;
  margin-top: 20rpx;
}

.related-scroll {
  max-height: 400rpx;
}

.related-item {
  display: inline-block;
  width: 200rpx;
  margin-right: 20rpx;
  margin-bottom: 20rpx;
}

.related-thumb {
  width: 200rpx;
  height: 150rpx;
  border-radius: 12rpx;
}

.related-name {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: var(--text-primary);
}

/* 底部操作 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx;
  background: white;
  border-top: 1rpx solid var(--border-color);
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
}

.btn-primary, .btn-secondary {
  flex: 1;
}
