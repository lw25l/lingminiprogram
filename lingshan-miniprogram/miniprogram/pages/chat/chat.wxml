<!--pages/chat/chat.wxml-->
<view class="chat-container">
  <!-- 数字人展示区 -->
  <view class="digital-human-section" wx:if="{{showDigitalHuman}}">
    <view class="human-container">
      <!-- 数字人动画 -->
      <view class="human-avatar {{isSpeaking ? 'speaking' : ''}}">
        <image class="avatar-img" src="{{digitalHumanAvatar}}" mode="aspectFit"></image>
        <!-- 语音波形动画 -->
        <view class="voice-wave" wx:if="{{isSpeaking}}">
          <view class="wave-bar" wx:for="{{8}}" wx:key="index"></view>
        </view>
      </view>
      <text class="human-name">{{digitalHumanName}}</text>
      <text class="human-title">您的专属AI导游</text>
    </view>
  </view>

  <!-- 聊天区域 -->
  <scroll-view 
    class="chat-messages" 
    scroll-y="{{true}}" 
    scroll-top="{{scrollTop}}"
    bindscrolltoupper="onScrollToUpper"
  >
    <!-- 欢迎消息 -->
    <view class="welcome-message" wx:if="{{messages.length === 0}}">
      <image class="welcome-avatar" src="{{digitalHumanAvatar}}" mode="aspectFit"></image>
      <view class="welcome-content">
        <text class="welcome-title">您好，我是{{digitalHumanName}}</text>
        <text class="welcome-desc">灵山胜境AI智能导游，很高兴为您服务！</text>
        <text class="welcome-desc">我可以为您讲解景点、推荐路线、回答问题。</text>
      </view>
    </view>

    <!-- 快捷问题 -->
    <view class="quick-questions" wx:if="{{messages.length === 0}}">
      <text class="quick-title">您可以问我：</text>
      <view class="question-list">
        <view 
          class="question-item" 
          wx:for="{{quickQuestions}}" 
          wx:key="index"
          bindtap="sendQuickQuestion"
          data-question="{{item}}"
        >
          {{item}}
        </view>
      </view>
    </view>

    <!-- 消息列表 -->
    <view class="message-list">
      <block wx:for="{{messages}}" wx:key="id">
        <!-- 用户消息 -->
        <view class="message-item user-message" wx:if="{{item.role === 'user'}}">
          <view class="message-content user-content">
            <text>{{item.content}}</text>
          </view>
          <image class="message-avatar" src="{{userAvatar}}" mode="aspectFill"></image>
        </view>

        <!-- AI回复 -->
        <view class="message-item ai-message" wx:else>
          <image class="message-avatar" src="{{digitalHumanAvatar}}" mode="aspectFill"></image>
          <view class="message-content ai-content">
            <!-- 文本内容 -->
            <text class="message-text">{{item.content}}</text>
            
            <!-- 推荐景点卡片 -->
            <view class="recommend-cards" wx:if="{{item.recommendations && item.recommendations.length > 0}}">
              <view 
                class="recommend-card" 
                wx:for="{{item.recommendations}}" 
                wx:for-item="rec" 
                wx:key="id"
                bindtap="goToAttraction"
                data-id="{{rec.id}}"
              >
                <image class="rec-image" src="{{rec.image}}" mode="aspectFill"></image>
                <view class="rec-info">
                  <text class="rec-name">{{rec.name}}</text>
                  <text class="rec-desc">{{rec.highlight}}</text>
                </view>
              </view>
            </view>

            <!-- 操作按钮 -->
            <view class="message-actions" wx:if="{{item.actions && item.actions.length > 0}}">
              <view 
                class="action-btn" 
                wx:for="{{item.actions}}" 
                wx:for-item="action" 
                wx:key="type"
                bindtap="handleAction"
                data-action="{{action}}"
              >
                {{action.text}}
              </view>
            </view>
          </view>
        </view>
      </block>

      <!-- 加载中 -->
      <view class="loading-message" wx:if="{{isLoading}}">
        <image class="message-avatar" src="{{digitalHumanAvatar}}" mode="aspectFill"></image>
        <view class="loading-content">
          <view class="typing-indicator">
            <view class="dot" wx:for="{{3}}" wx:key="index"></view>
          </view>
          <text class="loading-text">正在思考中...</text>
        </view>
      </view>
    </view>

    <!-- 底部占位 -->
    <view class="bottom-placeholder"></view>
  </scroll-view>

  <!-- 输入区域 -->
  <view class="input-area {{isRecording ? 'recording' : ''}}">
    <!-- 语音输入按钮 -->
    <view 
      class="voice-btn {{isRecording ? 'recording' : ''}}" 
      bindtouchstart="startRecording"
      bindtouchend="stopRecording"
      bindlongpress="cancelRecording"
    >
      <image class="voice-icon" src="/assets/icons/microphone.png" mode="aspectFit"></image>
    </view>

    <!-- 文本输入框 -->
    <input 
      class="text-input"
      type="text"
      placeholder="请输入您的问题..."
      value="{{inputText}}"
      bindinput="onInputChange"
      bindconfirm="sendMessage"
      confirm-type="send"
      adjust-position="{{true}}"
    />

    <!-- 发送按钮 -->
    <view class="send-btn {{inputText.length > 0 ? 'active' : ''}}" bindtap="sendMessage">
      <image class="send-icon" src="/assets/icons/send.png" mode="aspectFit"></image>
    </view>
  </view>

  <!-- 语音识别弹窗 -->
  <view class="voice-modal" wx:if="{{showVoiceModal}}">
    <view class="voice-modal-content">
      <view class="voice-wave-large">
        <view class="wave-bar-large" wx:for="{{8}}" wx:key="index"></view>
      </view>
      <text class="voice-tip">{{voiceTip}}</text>
      <text class="voice-result" wx:if="{{voiceResult}}">{{voiceResult}}</text>
    </view>
  </view>
</view>
