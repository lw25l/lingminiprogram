/* pages/chat/chat.wxss */

.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg-primary);
}

/* 数字人展示区 */
.digital-human-section {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  padding: 40rpx;
  flex-shrink: 0;
}

.human-container {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.human-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.8);
  background: white;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: visible;
  animation: float 3s ease-in-out infinite;
}

.avatar-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
}

.human-avatar.speaking {
  animation: pulse 1s ease-in-out infinite;
}

/* 语音波形 */
.voice-wave {
  position: absolute;
  bottom: -30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.wave-bar {
  width: 6rpx;
  height: 20rpx;
  background: white;
  border-radius: 3rpx;
  animation: wave 0.5s ease-in-out infinite;
}

.wave-bar:nth-child(1) { animation-delay: 0s; }
.wave-bar:nth-child(2) { animation-delay: 0.1s; }
.wave-bar:nth-child(3) { animation-delay: 0.2s; }
.wave-bar:nth-child(4) { animation-delay: 0.3s; }
.wave-bar:nth-child(5) { animation-delay: 0.2s; }
.wave-bar:nth-child(6) { animation-delay: 0.1s; }
.wave-bar:nth-child(7) { animation-delay: 0s; }
.wave-bar:nth-child(8) { animation-delay: 0.1s; }

@keyframes wave {
  0%, 100% { height: 10rpx; }
  50% { height: 30rpx; }
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.human-name {
  font-size: 34rpx;
  font-weight: 600;
  color: white;
  margin-top: 20rpx;
}

.human-title {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 6rpx;
}

/* 聊天区域 */
.chat-messages {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
}

/* 欢迎消息 */
.welcome-message {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  margin-bottom: 30rpx;
}

.welcome-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-bottom: 20rpx;
}

.welcome-content {
  text-align: center;
}

.welcome-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 16rpx;
}

.welcome-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  display: block;
  line-height: 1.6;
}

/* 快捷问题 */
.quick-questions {
  padding: 20rpx;
  margin-bottom: 30rpx;
}

.quick-title {
  font-size: 28rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 20rpx;
}

.question-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.question-item {
  padding: 16rpx 28rpx;
  background: white;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
  transition: all 0.3s;
}

.question-item:active {
  background: var(--primary-color);
  color: white;
}

/* 消息列表 */
.message-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.message-item {
  display: flex;
  align-items: flex-start;
  animation: fadeIn 0.3s ease-out;
}

.user-message {
  justify-content: flex-end;
}

.ai-message {
  justify-content: flex-start;
}

.message-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.user-message .message-avatar {
  margin-left: 20rpx;
}

.ai-message .message-avatar {
  margin-right: 20rpx;
}

.message-content {
  max-width: 560rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  word-break: break-word;
}

.user-content {
  background: var(--primary-color);
  color: white;
  border-bottom-right-radius: 6rpx;
}

.ai-content {
  background: white;
  color: var(--text-primary);
  border-bottom-left-radius: 6rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.message-text {
  font-size: 28rpx;
  line-height: 1.6;
  display: block;
}

/* 推荐卡片 */
.recommend-cards {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.recommend-card {
  display: flex;
  background: var(--bg-primary);
  border-radius: 12rpx;
  overflow: hidden;
}

.rec-image {
  width: 120rpx;
  height: 90rpx;
  flex-shrink: 0;
}

.rec-info {
  flex: 1;
  padding: 12rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.rec-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.rec-desc {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

/* 操作按钮 */
.message-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.action-btn {
  padding: 12rpx 24rpx;
  background: rgba(74, 144, 217, 0.1);
  color: var(--primary-color);
  border-radius: 20rpx;
  font-size: 26rpx;
}

/* 加载中 */
.loading-message {
  display: flex;
  align-items: flex-start;
  animation: fadeIn 0.3s ease-out;
}

.loading-content {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background: white;
  border-radius: 20rpx;
  border-bottom-left-radius: 6rpx;
}

.typing-indicator {
  display: flex;
  gap: 8rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  background: var(--primary-color);
  border-radius: 50%;
  animation: typing 1s infinite;
}

.dot:nth-child(1) { animation-delay: 0s; }
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes typing {
  0%, 100% { opacity: 0.3; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1); }
}

.loading-text {
  font-size: 26rpx;
  color: var(--text-light);
}

.bottom-placeholder {
  height: 20rpx;
}

/* 输入区域 */
.input-area {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: white;
  border-top: 1rpx solid var(--border-color);
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.voice-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--bg-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.3s;
}

.voice-btn.recording {
  background: var(--error-color);
}

.voice-icon {
  width: 40rpx;
  height: 40rpx;
}

.text-input {
  flex: 1;
  height: 80rpx;
  padding: 0 30rpx;
  margin: 0 20rpx;
  background: var(--bg-primary);
  border-radius: 40rpx;
  font-size: 28rpx;
}

.send-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--bg-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.3s;
}

.send-btn.active {
  background: var(--primary-color);
}

.send-icon {
  width: 40rpx;
  height: 40rpx;
}

/* 语音识别弹窗 */
.voice-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.voice-modal-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx;
  background: white;
  border-radius: 30rpx;
}

.voice-wave-large {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-bottom: 30rpx;
}

.wave-bar-large {
  width: 10rpx;
  height: 60rpx;
  background: var(--primary-color);
  border-radius: 5rpx;
  animation: wave 0.5s ease-in-out infinite;
}

.voice-tip {
  font-size: 30rpx;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.voice-result {
  font-size: 28rpx;
  color: var(--text-secondary);
}
