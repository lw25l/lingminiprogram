/* pages/map/map.wxss */

.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg-primary);
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: white;
  border-bottom: 1rpx solid var(--border-color);
}

.search-input {
  flex: 1;
  height: 70rpx;
  padding: 0 30rpx;
  background: var(--bg-primary);
  border-radius: 35rpx;
  font-size: 28rpx;
}

.search-icon {
  width: 40rpx;
  height: 40rpx;
  margin-left: 16rpx;
}

/* 筛选标签 */
.filter-tags {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx;
  background: white;
  gap: 10rpx;
}

.filter-tag {
  padding: 12rpx 24rpx;
  background: var(--bg-primary);
  color: var(--text-secondary);
  font-size: 26rpx;
  border-radius: 30rpx;
  transition: all 0.3s;
}

.filter-tag.active {
  background: var(--primary-color);
  color: white;
}

/* 地图区域 */
.map-section {
  position: relative;
  flex: 1;
}

.attraction-list {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 280rpx;
  background: white;
  border-left: 1rpx solid var(--border-color);
  overflow-y: auto;
}

.list-header {
  padding: 30rpx 20rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.list-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.list-count {
  font-size: 24rpx;
  color: var(--text-light);
}

.attraction-card {
  display: flex;
  padding: 20rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.attraction-thumb {
  width: 120rpx;
  height: 90rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.attraction-info {
  flex: 1;
  margin-left: 16rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.attraction-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.attraction-meta {
  display: flex;
  gap: 16rpx;
}

.meta-item {
  font-size: 22rpx;
  color: var(--text-light);
}

.attraction-distance {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.dist-icon {
  width: 20rpx;
  height: 20rpx;
}

.attraction-distance text {
  font-size: 22rpx;
  color: var(--text-light);
}

.attraction-rating {
  display: flex;
  align-items: center;
}

.rating-score {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--primary-color);
}

.rating-stars {
  font-size: 20rpx;
  color: #FFB347;
}

.load-more, .empty-state {
  padding: 40rpx;
  text-align: center;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-light);
}

/* 地图操作按钮 */
.map-actions {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  background: white;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.15);
  overflow: hidden;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  width: 60rpx;
  height: 60rpx;
  font-size: 24rpx;
  color: var(--text-primary);
}

.action-icon {
  width: 36rpx;
  height: 36rpx;
}

.action-btn:first-child {
  border-bottom: 1rpx solid var(--border-color);
}

/* 底部导航 */
.bottom-nav {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 16rpx 0;
  background: white;
  border-top: 1rpx solid var(--border-color);
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.nav-icon {
  width: 44rpx;
  height: 44rpx;
  margin-bottom: 4rpx;
}

.nav-label {
  font-size: 22rpx;
  color: var(--text-light);
}

.nav-item.active .nav-label {
  color: var(--primary-color);
}
